<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/deep_blue">

    <!-- Elegant Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp"
        android:background="@drawable/header_gradient_app_selection">

        <!-- Title Row with Kairos Balance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/select_apps_title"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Kairos Balance Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/kairos_badge_small"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/kairosBalanceTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFD93D"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_apps_subtitle"
            android:textColor="#AABBCC"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Premium Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/search_bar_premium"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#8899AA"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/searchEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/search_apps"
                android:textColor="@android:color/white"
                android:textColorHint="#667788"
                android:textSize="16sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- Apps Count Indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:background="#0A0A2E">

        <View
            android:layout_width="4dp"
            android:layout_height="16dp"
            android:background="#64B5F6"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/appsCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/apps_available"
            android:textColor="#8899AA"
            android:textSize="13sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/restrictedCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#64B5F6"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Apps List with Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A1A4E" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/appsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:paddingTop="8dp"
        android:clipToPadding="false"
        android:background="@color/deep_blue" />

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_bar_gradient"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/done"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="#1E88E5"
            app:cornerRadius="16dp"
            app:rippleColor="#64B5F6"
            app:elevation="4dp" />

    </LinearLayout>

</LinearLayout>
