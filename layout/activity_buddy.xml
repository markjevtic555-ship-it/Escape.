<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_blue"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/buddy_system"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/utm_times" />

            <LinearLayout
                android:id="@+id/connectionStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/buddy_status_badge_disconnected"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:gravity="center">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot_red" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Not Connected"
                    android:textColor="#FF5252"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Your Buddy Code Section (only shown when disconnected) -->
        <LinearLayout
            android:id="@+id/buddyCodeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/buddy_code_card"
            android:padding="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/your_buddy_code"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/buddyCodeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LOADING..."
                    android:textColor="@android:color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.2" />

                <LinearLayout
                    android:id="@+id/copyCodeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/buddy_copy_button"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="10dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/copy"
                        android:textColor="#64B5F6"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/share_code_message"
                android:textColor="#666666"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Connect to Buddy Section -->
        <LinearLayout
            android:id="@+id/connectSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/auth_card_background"
            android:padding="24dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connect_to_buddy"
                android:textColor="#888888"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/buddyCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/auth_input_background"
                android:padding="16dp"
                android:textColor="@android:color/white"
                android:textColorHint="#666666"
                android:hint="Enter buddy code"
                android:inputType="textCapCharacters"
                android:maxLength="8"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/connectErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="13sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/buddy_connect_button"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/connectButtonText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/connect_to_buddy_button"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/connectProgress"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="12dp"
                    android:visibility="gone"
                    android:indeterminateTint="@android:color/white" />

            </LinearLayout>

        </LinearLayout>

        <!-- Connected Buddy Section -->
        <LinearLayout
            android:id="@+id/connectedSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Buddy Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/buddy_connected_card"
                android:padding="24dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp">

                        <View
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/buddy_avatar_glow" />

                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:background="@drawable/buddy_avatar_circle"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/buddyInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="B"
                                android:textColor="@android:color/white"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/buddyNameText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/your_buddy"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/buddyEmailText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="buddy@email.com"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/buddy_live_badge"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:gravity="center">

                        <View
                            android:id="@+id/liveDot"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/status_dot_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/live"
                            android:textColor="#4CAF50"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Current App Usage Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/buddy_usage_card"
                android:padding="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/currently_using"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <!-- App Icon -->
                    <ImageView
                        android:id="@+id/buddyCurrentAppIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/buddyCurrentAppName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="No app in use"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/buddyCurrentAppDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textColor="#64B5F6"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="in this session"
                        android:textColor="#666666"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Buddy Restricted Apps List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/restricted_apps"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/buddyAppsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- Penalty Card -->
            <LinearLayout
                android:id="@+id/penaltyCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/buddy_penalty_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="24sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/penalty_active"
                        android:textColor="#FF5252"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/penaltyReasonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/buddy_exceeded_limit"
                        android:textColor="#FFCDD2"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Disconnect Button -->
            <LinearLayout
                android:id="@+id/disconnectButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/buddy_disconnect_button"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/disconnect_buddy"
                    android:textColor="#FF5252"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/buddy_info_card"
            android:padding="20dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_it_works"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_it_works_description"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>

