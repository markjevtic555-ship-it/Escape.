<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_blue">

    <!-- Subtle gradient overlay -->
    <View
        android:id="@+id/gradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/focus_gradient_overlay" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Greeting -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/greetingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/focus_mode"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/earn_kairos_focused"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Kairos Balance Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/kairos_badge_focus"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/kairosBalanceTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 ⧖"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/utm_times" />

            </LinearLayout>

        </LinearLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:id="@+id/statsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <!-- Total Sessions -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/focus_stat_card"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧘"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/totalSessionsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sessions"
                    android:textColor="#888888"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Total Time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/focus_stat_card"
                android:padding="12dp"
                android:layout_marginHorizontal="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/totalTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.5h"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_focus"
                    android:textColor="#888888"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Current Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/focus_stat_card"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/streakText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3"
                    android:textColor="#FF9800"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_streak"
                    android:textColor="#888888"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Center Focus Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Real-time clock -->
            <TextView
                android:id="@+id/clockTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#666666"
                android:textSize="14sp"
                android:letterSpacing="0.2"
                android:alpha="0"
                android:layout_marginBottom="16dp" />

            <!-- Outer ring (decorative) -->
            <FrameLayout
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:background="@drawable/focus_outer_ring">

                <!-- Middle ring with pulse animation -->
                <FrameLayout
                    android:id="@+id/pulseRing"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center"
                    android:background="@drawable/focus_pulse_ring" />

                <!-- Main circular button -->
                <FrameLayout
                    android:id="@+id/circleButton"
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center"
                    android:background="@drawable/focus_circle_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="8dp">

                    <!-- Content inside circle -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <!-- Start icon -->
                        <TextView
                            android:id="@+id/startIconView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶"
                            android:textSize="36sp"
                            android:textColor="#FFFFFF" />

                        <!-- Start text -->
                        <TextView
                            android:id="@+id/startTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/start"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.2"
                            android:layout_marginTop="8dp" />

                        <!-- Timer display (hidden initially) -->
                        <TextView
                            android:id="@+id/timerTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00:00"
                            android:textColor="#FFFFFF"
                            android:textSize="42sp"
                            android:fontFamily="sans-serif-light"
                            android:alpha="0"
                            android:visibility="gone" />

                        <!-- Session status (hidden initially) -->
                        <TextView
                            android:id="@+id/sessionStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stay_focused"
                            android:textColor="#888888"
                            android:textSize="12sp"
                            android:alpha="0"
                            android:visibility="gone"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </FrameLayout>

            </FrameLayout>

            <!-- Tap hint -->
            <TextView
                android:id="@+id/tapHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_begin"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="20dp" />

        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom Section: Today's Sessions -->
        <LinearLayout
            android:id="@+id/todaySessionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/focus_today_card"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/todays_focus"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/todayTimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1h 20m"
                    android:textColor="#4CAF50"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Progress bar for daily goal -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/focus_progress_bg">

                <View
                    android:id="@+id/todayProgressBar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/focus_progress_fill" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/goalHoursText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/goal_hours"
                    android:textColor="#666666"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/todayPercentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/percent_complete"
                    android:textColor="#666666"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
