<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background_premium"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- App Icon and Name Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/dialogAppIcon"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/app_icon_background"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/set_limit_title"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialogMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#8899AA"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A2A4A"
        android:layout_marginBottom="24dp" />

    <!-- Time Picker Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/daily_limit"
        android:textColor="#8899AA"
        android:textSize="14sp"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp" />

    <!-- Wheel Picker Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Hours Picker -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <NumberPicker
                android:id="@+id/hoursPicker"
                android:layout_width="80dp"
                android:layout_height="160dp"
                android:theme="@style/NumberPickerTheme"
                android:descendantFocusability="blocksDescendants" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hours_label"
                android:textColor="#64B5F6"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Separator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=":"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Minutes Picker -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <NumberPicker
                android:id="@+id/minutesPicker"
                android:layout_width="80dp"
                android:layout_height="160dp"
                android:theme="@style/NumberPickerTheme"
                android:descendantFocusability="blocksDescendants" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/minutes_label"
                android:textColor="#64B5F6"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Quick Select Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/quickSelect15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15m"
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:background="@drawable/quick_select_background"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/quickSelect30"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30m"
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:background="@drawable/quick_select_background"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/quickSelect1h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1h"
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:background="@drawable/quick_select_background"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/quickSelect2h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2h"
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:background="@drawable/quick_select_background"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp" />

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/cancel"
            android:textColor="#8899AA"
            android:textSize="15sp"
            android:textAllCaps="false"
            app:backgroundTint="#0A1530"
            app:strokeColor="#2A3A5A"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp"
            app:rippleColor="#1A2A4A" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/set_limit"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="#1E88E5"
            app:cornerRadius="14dp"
            app:rippleColor="#64B5F6" />

    </LinearLayout>

    <!-- Remove Limit Button (shown when editing existing limit) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonRemoveLimit"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:text="@string/remove_limit"
        android:textColor="#FF6B6B"
        android:textSize="14sp"
        android:textAllCaps="false"
        app:backgroundTint="@android:color/transparent"
        app:cornerRadius="12dp"
        app:rippleColor="#30FF6B6B"
        android:visibility="gone" />

</LinearLayout>
