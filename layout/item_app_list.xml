<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/app_item_background"
    android:gravity="center_vertical"
    android:elevation="2dp">

    <!-- App Icon with Glow Effect -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp">

        <!-- Icon Background Glow -->
        <View
            android:id="@+id/iconGlow"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/icon_glow_background"
            android:visibility="gone" />

        <!-- App Icon -->
        <ImageView
            android:id="@+id/appIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:scaleType="centerCrop"
            android:background="@drawable/app_icon_background" />

    </FrameLayout>

    <!-- App Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/limitInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8899AA"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Time Limit Badge / Set Button -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- When limit is set - show time badge -->
        <LinearLayout
            android:id="@+id/timeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/time_badge_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/timeBadgeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64B5F6"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- When no limit - show add button -->
        <ImageView
            android:id="@+id/addLimitButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_add_time"
            android:background="@drawable/add_button_background"
            android:padding="10dp"
            android:visibility="visible" />

    </FrameLayout>

</LinearLayout>
